zi <- rnorm(n)
xe <- 0.6 * zi + rnorm(n)
Xiv <- cbind(X, xe = xe)
yiv <- y + 0.7 * xe
miv <- xhdfe_fit(yiv, Xiv, fes = list(firm = firm),
                 endogenous = "xe", instruments = cbind(z1 = zi))
